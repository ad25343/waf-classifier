# ═══════════════════════════════════════════════════════════════════
#  WAF Classifier — Full Configuration Reference
#  Copy this file to .env and fill in the values for your deployment.
#  Every block is optional — only configure what you need.
# ═══════════════════════════════════════════════════════════════════


# ╔══════════════════════════════════════════════════════════════════╗
# ║  AI BACKEND — choose exactly ONE of the four options below      ║
# ╚══════════════════════════════════════════════════════════════════╝

# ── Option 1: Direct Anthropic API (simplest, good for local dev) ──
ANTHROPIC_API_KEY=sk-ant-your-key-here


# ── Option 2: AWS Bedrock (direct — no gateway) ────────────────────
# AWS credentials are picked up from environment, ~/.aws/credentials,
# or an EC2/ECS instance role.  No ANTHROPIC_API_KEY needed.
# AWS_ACCESS_KEY_ID=AKIA...
# AWS_SECRET_ACCESS_KEY=...
# AWS_DEFAULT_REGION=us-east-1
# BEDROCK_MODEL_ID=anthropic.claude-sonnet-4-5-20250929-v1:0


# ── Option 3: PortKey AI Gateway ───────────────────────────────────
# PortKey proxies to Bedrock (or any provider) with observability,
# caching, fallbacks, and routing.  Install: pip install portkey-ai
#
# AI_GATEWAY=portkey
# PORTKEY_API_KEY=pk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# PORTKEY_VIRTUAL_KEY=anthropic-bedrock-xxxxxxxxxxxxxxxx
#                     ↑ create in PortKey dashboard → Virtual Keys
# PORTKEY_GATEWAY_URL=https://api.portkey.ai/v1
#                     or your self-hosted gateway URL
# PORTKEY_MODEL=claude-sonnet-4-5-20250929
#
# Notes:
#   • The virtual key bundles the provider (Bedrock/Anthropic) + its
#     credentials, so no ANTHROPIC_API_KEY or AWS_* keys are needed here.
#   • PORTKEY_GATEWAY_URL defaults to https://api.portkey.ai/v1 if unset.
#   • portkey-ai SDK is optional — raw headers are used as fallback.


# ── Option 4: Apigee API Gateway → Bedrock ─────────────────────────
# Apigee acts as a reverse proxy in front of AWS Bedrock.
# Auth: OAuth2 client-credentials flow (token auto-refreshed).
#
# AI_GATEWAY=apigee
# APIGEE_GATEWAY_URL=https://api.yourorg.com/ai-gateway/v1
#                    ↑ the Apigee proxy base URL (no trailing slash)
# APIGEE_TOKEN_URL=https://login.yourorg.com/oauth2/token
#                  ↑ token endpoint for client-credentials grant
# APIGEE_CLIENT_ID=your-apigee-client-id
# APIGEE_CLIENT_SECRET=your-apigee-client-secret
# BEDROCK_MODEL_ID=anthropic.claude-sonnet-4-5-20250929-v1:0
#                  ↑ passed as the model name in the API request
#
# Optional — extra HTTP headers your Apigee proxy expects:
# APIGEE_EXTRA_HEADERS={"x-api-version":"2024-01","x-env":"prod"}


# ╔══════════════════════════════════════════════════════════════════╗
# ║  AUTHENTICATION / SSO                                           ║
# ╚══════════════════════════════════════════════════════════════════╝

# AUTH_MODE=none   (default) — all routes are public, no login required
# AUTH_MODE=oidc             — OIDC/OAuth2 SSO; all routes require login

# ── OIDC SSO (AUTH_MODE=oidc) ──────────────────────────────────────
# Works with any OIDC-compliant IdP:
#   • Okta:         https://{domain}.okta.com
#   • Azure AD:     https://login.microsoftonline.com/{tenant}/v2.0
#   • Ping Identity: https://auth.pingone.com/{env-id}/as
#   • Keycloak:     https://keycloak.yourorg.com/realms/{realm}
#   • Google:       https://accounts.google.com
#
# AUTH_MODE=oidc
#
# OIDC_DISCOVERY_URL=https://login.microsoftonline.com/{tenant}/v2.0
#   ↑ The app appends /.well-known/openid-configuration automatically
#     unless the URL already ends with that path.
#
# OIDC_CLIENT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
# OIDC_CLIENT_SECRET=your-client-secret
#
# OIDC_REDIRECT_URI=https://app.yourorg.com/auth/callback
#   ↑ Must be registered as an allowed redirect URI in your IdP.
#     For local dev: http://localhost:8080/auth/callback
#
# SESSION_SECRET_KEY=change-me-to-a-64-char-random-string
#   ↑ Required for stable sessions across restarts / multiple workers.
#     Generate with: python -c "import secrets; print(secrets.token_hex(32))"
#
# OIDC_SCOPES=openid email profile
#   ↑ Default. Add "groups" or custom scopes if your IdP requires them.
#
# OIDC_AUDIENCE=api://your-resource-server
#   ↑ Required by Okta resource servers and some Azure API configs.
#     Leave unset for most setups.


# ╔══════════════════════════════════════════════════════════════════╗
# ║  SERVER & DEPLOYMENT                                            ║
# ╚══════════════════════════════════════════════════════════════════╝

# Port the Flask server listens on.
PORT=8080

# URL prefix when the app is served under a sub-path by a reverse proxy.
# Leave blank for root-path / local development (http://localhost:8080/).
# Example: APPLICATION_ROOT=/waf-classifier
APPLICATION_ROOT=
