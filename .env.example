# ── WAF Classifier Configuration ───────────────────────────────────
# Copy this file to .env and fill in the values for your deployment.


# ── AI Backend — choose ONE ─────────────────────────────────────────

# Option 1: Direct Anthropic API (takes priority when set)
# Get your key at https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Option 2: AWS Bedrock (used automatically when ANTHROPIC_API_KEY is absent)
# AWS credentials are read from environment or ~/.aws/credentials
# AWS_ACCESS_KEY_ID=AKIA...
# AWS_SECRET_ACCESS_KEY=...
# AWS_DEFAULT_REGION=us-east-1
# BEDROCK_MODEL_ID=anthropic.claude-sonnet-4-5-20250929-v1:0


# ── Server ──────────────────────────────────────────────────────────
# PORT=8080
