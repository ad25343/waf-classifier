# WAF Classifier — Environment Configuration
# Copy this file to .env and fill in your values.
# Lines starting with # are comments and are ignored.

# ── AI Backend ────────────────────────────────────────────────────────
# Option A: Anthropic API (recommended)
# Get a key at https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Option B: AWS Bedrock (used automatically when ANTHROPIC_API_KEY is absent)
# Credentials come from ~/.aws/credentials or standard AWS env vars —
# do not put AWS_ACCESS_KEY_ID / AWS_SECRET_ACCESS_KEY here.
# AWS_DEFAULT_REGION=us-east-1
# BEDROCK_MODEL_ID=anthropic.claude-sonnet-4-5-20250929-v1:0

# ── Server ────────────────────────────────────────────────────────────
# Port the Flask server listens on. Default: 8080
# PORT=8080

# ── Reverse-Proxy / Sub-Path Deployment ──────────────────────────────
# Set this when the app is served under a URL prefix by a reverse proxy
# (nginx, Apache, AWS ALB, etc.). Leave commented out for root-path /
# local development — no other changes needed.
# Example: app accessible at https://yourserver.com/h591-wafui/
# APPLICATION_ROOT=/h591-wafui
